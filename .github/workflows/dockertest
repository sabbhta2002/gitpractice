name: CI
 
on:
  push:
    branches: ["main"]
  pull_request:
    branches: ["main"]
  workflow_dispatch:
 
jobs:
  Logintodockerhub:
    runs-on: ubuntu-latest
    environment: Dev1
    steps:
      - uses: actions/checkout@v3
 
      - name: Docker login
        uses: docker/login-action@v2.1.0
        with:
          registry: registry-1.docker.io
          username: ${{ secrets.DOCKERHUBUSERNAME }}
          password: ${{ secrets.DOCKERHUBPASSWORD }}
 
  LogintodockerhubQA:
    runs-on: ubuntu-latest
    environment: Qa
    steps:
      - uses: actions/checkout@v3
 
      - name: Docker login
        uses: docker/login-action@v2.1.0
        with:
          registry: registry-1.docker.io
          username: ${{ secrets.DOCKERHUBUSERNAME }}
          password: ${{ secrets.DOCKERHUBPASSWORD }}
